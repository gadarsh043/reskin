# Reskin runtime state (written in projects where the skill runs — do not commit)
#   .reskin/preflight.json      — design-token scan + comprehension + concept cache
#   .reskin/understanding.md    — Site Understanding report (user-reviewed)
#   .reskin/concept.md          — Concept Brief (optional; user-reviewed)
#   .reskin/change-plan.md      — Structure + per-unit dial plan (user-reviewed)
#   .reskin/verify-report.md    — Post-redesign verification report
#   .reskin/log.json            — macrostructure / theme / concept rotation history
.reskin/

# `skills` CLI install lockfile — generated when `skills add` runs in this directory
skills-lock.json
.agents/
